{
  "application": {
    "name": "SigmaHQ RAG",
    "version": "1.0.0",
    "debug": false,
    "log_level": "INFO"
  },
  "database": {
    "path": "data/local/sigmahq.db",
    "backup_enabled": true,
    "backup_interval_hours": 24
  },
  "lm_studio": {
    "url": "http://localhost:1234",
    "timeout": 30,
    "max_tokens": 1000,
    "temperature": 0.7
  },
  "gradio": {
    "host": "0.0.0.0",
    "port": 8080,
    "share": false,
    "debug": false,
    "theme": "soft"
  },
  "rag": {
    "enabled": true,
    "n_results": 3,
    "min_score": 0.1,
    "chunk_size": 1000,
    "chunk_overlap": 100,
    "conversation_history_limit": 10
  },
  "file_processing": {
    "upload_max_size_mb": 50,
    "allowed_types": [
      ".pdf",
      ".txt",
      ".docx",
      ".png",
      ".jpg",
      ".jpeg"
    ],
    "max_concurrent": 5,
    "temp_dir": "data/local/temp"
  },
  "github": {
    "token": "",
    "clone_timeout": 300,
    "max_repos": 10
  },
  "security": {
    "allowed_hosts": [
      "*"
    ],
    "cors_origins": [
      "*"
    ],
    "session_timeout": 3600
  },
  "performance": {
    "max_memory_usage_mb": 2048,
    "cache_enabled": true,
    "cache_ttl": 3600,
    "streaming_enabled": true
  }
}